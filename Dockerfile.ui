FROM php:8.4-cli

ENV CONFIG_DIRECTORY=/Configs
ENV DOWNLOAD_DIRECTORY=/Downloads
ENV UI_DOWNLOAD_LABEL="/Downloads (persistent Docker storage)"
ENV PHP_CLI_SERVER_WORKERS=4

RUN apt-get update \
    && apt-get install -y --no-install-recommends git unzip libxml2-dev libsqlite3-dev \
    && docker-php-ext-install simplexml pdo_sqlite \
    && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer
WORKDIR /app
RUN mkdir -p /Configs /Downloads
COPY composer.json composer.lock ./
RUN composer install --no-dev --no-interaction --prefer-dist
COPY . .

EXPOSE 8787
CMD ["php", "bin/ui.php", "--host=0.0.0.0"]
